# Oakwood Maintenance â€” environment variables (build-spec Â§12).
# Copy to .env.local and fill in. NEVER commit real values.

# Database (PostgreSQL â€” Neon or Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Auth.js / NextAuth
AUTH_SECRET="a_secure_random_32_character_string_for_demo_purposes"
AUTH_URL="http://localhost:3000"

# App base URL (used in email links)
APP_URL= "http://localhost:3000"

# Email (Resend or SMTP provider equivalent)
RESEND_API_KEY=
FROM_EMAIL="Oakwood Property Management <maintenance@oakwoodpm.co.uk>"
TEAM_INBOX_EMAIL=maintenance@oakwoodpm.co.uk

# Object storage (S3-compatible â€” Cloudflare R2 or AWS S3)
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_BASE_URL=

# Rate limiting (e.g. Upstash Redis â€” optional but recommended)
RATE_LIMIT_REDIS_URL=
